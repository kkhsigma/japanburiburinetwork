{
  "name": "jbn-backend",
  "version": "1.2.0",
  "description": "JBN (Japan Botanical Network) Backend - Regulatory Intelligence System",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/migrate.ts && tsx src/db/seed.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "pg": "^8.13.0",
    "drizzle-orm": "^0.38.0",
    "bullmq": "^5.25.0",
    "ioredis": "^5.4.0",
    "cheerio": "^1.0.0",
    "pdf-parse": "^1.1.1",
    "rss-parser": "^3.13.0",
    "date-fns": "^4.1.0",
    "zod": "^3.24.0",
    "dotenv": "^16.4.0",
    "winston": "^3.17.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "drizzle-kit": "^0.30.0",
    "vitest": "^2.1.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  }
}
